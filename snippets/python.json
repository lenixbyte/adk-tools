      "    name='${1:my_agent}',",
      "    model='${2:gemini-2.0-flash}',",
      "    description='${3:Root agent}',",
      "    instruction='${4:You are a helpful assistant.}',",
      "    tools=[${5}],",
      ")"
    ],
    "description": "ADK root_agent (required entry point)"
  },
