      "    Args:",
      "        ${2}: ${6:Parameter description}",
      "",
      "    Returns:",
      "        ${7:Return value description}",
      "    \"\"\"",
      "    ${0:return ''}"
    ],
    "description": "ADK tool function (docstring required for LLM)"
  },
