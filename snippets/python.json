  "ADK Full Agent File": {
    "prefix": "adk-agent-file",
    "body": [
      "from google.adk.agents import LlmAgent",
      "",
      "",
      "def ${1:greet}(name: str) -> str:",
      "    \"\"\"Greet a person by name.",
      "",
      "    Args:",
      "        name: The person's name.",
      "",
      "    Returns:",
      "        A greeting string.",
      "    \"\"\"",
      "    return f'Hello, {name}!'",
      "",
      "",
      "root_agent = LlmAgent(",
      "    name='${2:my_agent}',",
      "    model='${3:gemini-2.0-flash}',",
      "    description='${4:A helpful agent}',",
      "    instruction='${5:You are a helpful assistant. Use tools when needed.}',",
      "    tools=[${1:greet}],",
      ")"
