      "    tool_context: ToolContext,",
      ") -> Optional[dict]:",
      "    \"\"\"${1:Intercept tool calls — return a dict to skip actual execution.}\"\"\"",
      "    ${0:return None  # Return None to proceed normally}"
    ],
    "description": "ADK before_tool_callback"
  },
  "ADK Sequential Agent": {
    "prefix": "adk-sequential",
    "body": [
